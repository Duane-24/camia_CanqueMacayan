import tkinter as tk
from tkinter import messagebox

root = tk.Tk()
root.title("SmartSpend")
root.geometry("480x680")

# Variables
result_text = tk.StringVar()
percent_left_text = tk.StringVar()
percent_left_text.set("Remaining Percent: 90%")

# Function
def calculate():
    try:
        allowance = float(entry_allowance.get())

        if allowance <= 0:
            messagebox.showerror("Error", "Allowance must be greater than 0")
            return

        emergency_percent = 10
        remaining_percent = 90

        toiletries = float(entry_toiletries.get())
        misc = float(entry_misc.get())
        food = float(entry_food.get())
        school = float(entry_school.get())

        if toiletries < 0 or misc < 0 or food < 0 or school < 0:
            messagebox.showerror("Error", "No negative numbers!")
            return

        total_used = toiletries + misc + food + school

        if total_used > remaining_percent:
            messagebox.showerror("Error", "You exceeded the remaining 90%!")
            return

        remaining = remaining_percent - total_used
        percent_left_text.set(f"Remaining Percent: {remaining}%")

        if remaining > 0:
            messagebox.showinfo("Extra Found", f"You have extra {remaining}%. Added to Emergency Funds!")
            emergency_percent += remaining

        # Calculation
        emergency_money = allowance * emergency_percent / 100
        toiletries_money = allowance * toiletries / 100
        misc_money = allowance * misc / 100
        food_money = allowance * food / 100
        school_money = allowance * school / 100

        # Output
        result_text.set(
            f"====== Budget List ======\n\n"
            f"Emergency Funds: ₱{emergency_money:.2f}\n"
            f"Toiletries: ₱{toiletries_money:.2f}\n"
            f"Miscellaneous: ₱{misc_money:.2f}\n"
            f"Food: ₱{food_money:.2f}\n"
            f"School: ₱{school_money:.2f}\n\n"
            f"Thanks for using SmartSpend! Use it again :)\n"
            f"Gabsahamnida, have a nice day!"
        )

    except:
        messagebox.showerror("Error", "Please enter numbers only!")

# UI

tk.Label(root, text="==== SmartSpend ====", font=("Edwardian Script ITC", 32)).pack(pady=10)

tk.Label(root, text="A Budget Calculator for Scholars :3").pack()
tk.Label(root, text="Note: 10% is automatically saved for Emergency Funds\n").pack()

# Allowance
tk.Label(root, text="Enter your total allowance:").pack()
entry_allowance = tk.Entry(root)
entry_allowance.pack()

# Inputs
tk.Label(root, text="\nToiletries (%)").pack()
entry_toiletries = tk.Entry(root)
entry_toiletries.pack()

tk.Label(root, text="Miscellaneous (%)").pack()
entry_misc = tk.Entry(root)
entry_misc.pack()

tk.Label(root, text="Food (%)").pack()
entry_food = tk.Entry(root)
entry_food.pack()

tk.Label(root, text="School (%)").pack()
entry_school = tk.Entry(root)
entry_school.pack()

# Remaining %
tk.Label(root, textvariable=percent_left_text, font=("Arial", 10)).pack(pady=5)

# Button
tk.Button(root, text="Calculate", command=calculate).pack(pady=10)

# Result
tk.Label(root, textvariable=result_text, justify="left").pack(pady=10)

root.mainloop()
