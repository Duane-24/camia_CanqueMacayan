# Welcome to SmartSpend!! :)
print("====o====o====o====o====o====o====o====")
print("|| ~ SmartSpend: Budget Calculator ~ ||")
print("====o====o====o====o====o====o====o====\n")
print("Welcome to SmartSpend: A Budget Calculator for Scholars :)\n")

# Asking Allowance
while True:
    try:
        allowance = float(input("Enter your total allowance: "))
        if allowance <= 0:
            print("Allowance should be greater than 0.\n")
        else:
            break
    except:
        print("Please refrain from entering letters or symbols.\n")

print("\nSo your allowance is ₱", allowance)

# Automatic emergency funds
emergency_percent = 10
remaining_percent = 100 - emergency_percent

print("We automatically deducted 10% for your Emergency funds")
print("Remaining:", remaining_percent, "%\n")

# Asking for Percentages
while True:
    try:
        remaining = remaining_percent

        toiletries = float(input("Toiletries (%): "))
        remaining -= toiletries
        print("Percent left:", remaining, "%\n")

        miscellaneous = float(input("Miscellaneous (%): "))
        remaining -= miscellaneous
        print("Percent left:", remaining, "%\n")

        food = float(input("Food (%): "))
        remaining -= food
        print("Percent left:", remaining, "%\n")

        school = float(input("School (%): "))
        remaining -= school
        print("Percent left:", remaining, "%\n")

        if toiletries < 0 or miscellaneous < 0 or food < 0 or school < 0:
            print("\nPlease no Negative numbers :)\n")
            continue

        total_used = toiletries + miscellaneous + food + school

        if total_used > remaining_percent:
            print("\nYou exceeded the remaining percentage (", remaining_percent, "% ). Try again.\n")
            continue

        extra = remaining_percent - total_used

        if extra > 0:
            print("\nIt seems that u have an extra , extra, "%", hmm.")
            print("Might as well add this to your Emergency Funds :3 .\n")
            emergency_percent += extra

        print("\nPercentages look good!\n")
        break

    except:
        print("\nPlease refrain from entering letters or symbols.\n")

#Budget Breakdown
print("\n====== Budget List ======\n")

emergency_money = allowance * emergency_percent / 100
toiletries_money = allowance * toiletries / 100
misc_money = allowance * miscellaneous / 100
food_money = allowance * food / 100
school_money = allowance * school / 100

print("Emergency Funds: ₱", emergency_money)
print("Toiletries: ₱", toiletries_money)
print("Miscellaneous: ₱", misc_money)
print("Food: ₱", food_money)
print("School: ₱", school_money)

print("\nThanks for using SmartSpend! Use it again :)")
print("Gamsahabnida, have a nice day!")
